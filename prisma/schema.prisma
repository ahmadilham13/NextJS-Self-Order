// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}
datasource db {
  provider = "postgresql"
}

model User {
  // ID ini sengaja tidak pakai default(cuid()), karena kita akan
  // menggunakan ID resmi yang dihasilkan oleh sistem supabase Auth
  id          String  @id
  email       String  @unique
  name        String?
  role        UserRole  @default(CUSTOMER)  // Peran default adalah pelanggan biaa
  createdAt   DateTime  @default(now())

  // Relasi: Satu user bisa memiliki riwayat banyak pesanan
  orders      Order[]
}

enum UserRole {
  CUSTOMER
  KITCHEN
  ADMIN
}

model Menu {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Int
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relasi: Satu menu bisa ada di banyak daftar pesanan
  orderItems OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  customerName  String      // Nama pembeli
  totalAmount   Int         // Total tagihan akhir (setelah diskon)
  discount      Int         @default(0) // Nominal potongan harga
  status        OrderStatus @default(PENDING) // Status Awal
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // RELASI BARU: Boleh kosong (?) jika yang memesan adalah Tamu (Guest)
  userId        String?     
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Relasi: Satu struk pesanan memiliki banyak item makanan
  items       OrderItem[]
}

model OrderItem {
  id            String      @id @default(cuid())
  quantity      Int         // Jumlah porsi
  price         Int         // Harga saat dibeli (Jaga-jaga jika harga menu naik di masa depan)
  
  // Relasi ke table Order (Jika order dihapus, itemnya ikut terhapus otomatis via Cascade)
  orderId       String
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Relasi ke table Menu
  menuId        String
  menu          Menu        @relation(fields: [menuId], references: [id])
}

// Enum (Tipe data khusus) untuk melacak pesanan di Kitchen Display
enum OrderStatus {
  PENDING       // Baru masuk
  COOKING       // Sedang dimasak
  READY         // Siap diantar/diambil
  CANCELLED     // Batal dipesan
  COMPLETED     // Selesai
}